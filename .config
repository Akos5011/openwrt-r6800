# Target
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_netgear_r6800=y

# LuCI
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y

# WiFi firmware
CONFIG_PACKAGE_kmod-mt7615-firmware=y

# TCP BBR congestion control
CONFIG_PACKAGE_kmod-tcp-bbr=y

# CAKE qdisc
CONFIG_PACKAGE_kmod-sched-cake=y
CONFIG_PACKAGE_tc-full=y

# zram compressed swap
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_kmod-lib-lzo=y

# USB support
CONFIG_PACKAGE_kmod-usb3=n
CONFIG_PACKAGE_kmod-usb2=n
CONFIG_PACKAGE_block-mount=n

# IFB device for CAKE ingress shaping
CONFIG_PACKAGE_kmod-ifb=y

# iptables DSCP marking and MSS clamping
CONFIG_PACKAGE_iptables-mod-ipopt=y

# HIGHMEM — kernel sees all ~250 MiB RAM instead of ~128 MiB
CONFIG_HIGHMEM=y
CONFIG_CFG80211_CERTIFICATION_ONUS=y
CONFIG_ATH_USER_REGD=y

# MIPS32 Release 2 ISA — MT7621A is an R2 core
CONFIG_CPU_MIPS32_R2=y
CONFIG_CPU_MIPS32_R1=n

# 1000 Hz kernel timer — lower scheduling latency
CONFIG_HZ_1000=y
CONFIG_HZ=1000
CONFIG_HZ_250=n
